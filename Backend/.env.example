# Database Connection URL
# Example: postgresql+asyncpg://user:password@localhost:5432/dbname
DATABASE_URL=

# Encryption Key (Must be 32 URL-safe base64-encoded bytes)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Sync retry configuration
# Maximum number of retry attempts when a sync fails (default: 3)
MAX_SYNC_RETRIES=3
# Seconds to wait between retry attempts (default: 5)
SYNC_RETRY_DELAY_SECONDS=5
